    }
    #gameMount {
      display:none;
      min-height:100vh;
    }
    .note {font-size:.9rem;color:var(--muted)}
    iframe {
      width:100%;
      min-height:100vh;
      border:none;
      display:block;
      background:transparent;
    }
  </style>
</head>
<body>
  <div id="menuView" class="shell">
    <div class="menu">
      <h1>Εκπαιδευτικό Ντάμας Version 2</h1>
      <p>Έτοιμη βάση με ελληνικό UI, σωστούς κανόνες, 4ψήφιο online room code, local mode και AI mode.</p>

      <div class="grid">
        <div class="card">
          <h2>Τοπικά</h2>
          <div class="row">
            <button id="playAiBtn" class="primary">Παίξε με AI</button>
            <button id="playLocalBtn" class="secondary">2 Παίκτες Τοπικά</button>
          </div>
          <p class="note">Άμεση δοκιμή χωρίς internet.</p>
        </div>

        <div class="card">
          <h2>Online δωμάτιο</h2>
          <div class="row">
            <button id="createRoomBtn" class="primary">Δημιουργία Δωματίου</button>
          </div>
          <div style="margin-top:10px">
            <input id="roomCodeInput" maxlength="4" placeholder="1234" inputmode="numeric" />
          </div>
          <div class="row" style="margin-top:10px">
            <button id="joinRoomBtn" class="secondary">Είσοδος με Κωδικό</button>
          </div>
          <p class="note">Ο δεύτερος παίκτης μπαίνει από οπουδήποτε με τον ίδιο 4ψήφιο κωδικό, όταν ο server είναι online.</p>
        </div>
      </div>

      <div id="statusBox" class="status">Έτοιμο.</div>
    </div>
  </div>

  <div id="gameMount">
    <div class="topbar" id="topbar">
      <div class="pill" id="modePill">Λειτουργία: Τοπικά</div>
      <div class="pill" id="roomPill">Δωμάτιο: ----</div>
      <button id="backBtn" style="width:auto">Επιστροφή</button>
    </div>
    <div id="gameContainer"></div>
  </div>

  <script>
    const statusBox = document.getElementById('statusBox');
    const roomCodeInput = document.getElementById('roomCodeInput');
    const modePill = document.getElementById('modePill');
    const roomPill = document.getElementById('roomPill');
    const menuView = document.getElementById('menuView');
    const gameMount = document.getElementById('gameMount');
    const gameContainer = document.getElementById('gameContainer');
    const topbar = document.getElementById('topbar');

    let socket = null;
    let roomCode = null;

    function setStatus(text) {
      statusBox.textContent = text;
    }

    function showGame(modeLabel) {
      menuView.style.display = 'none';
      gameMount.style.display = 'block';
      topbar.style.display = 'flex';
      modePill.textContent = 'Λειτουργία: ' + modeLabel;
      roomPill.textContent = 'Δωμάτιο: ' + (roomCode || '----');
      if (!gameContainer.dataset.loaded) {
        const iframe = document.createElement('iframe');
        iframe.src = 'game.html';
        gameContainer.appendChild(iframe);
        gameContainer.dataset.loaded = '1';
      }
    }

    function normalizeCode(value) {
      return (value || '').replace(/\D/g, '').slice(0, 4);
    }

    function connectSocket() {
      const proto = location.protocol === 'https:' ? 'wss:' : 'ws:';
      const wsUrl = window.CHECKERS_WS_URL || `${proto}//${location.host}`;
      socket = new WebSocket(wsUrl);

      socket.onopen = () => {
        setStatus('Συνδέθηκες στον online server.');
      };

      socket.onmessage = (event) => {
        const msg = JSON.parse(event.data);
        if (msg.type === 'room_created') {
          roomCode = msg.code;
          setStatus('Το δωμάτιο δημιουργήθηκε. Δώσε τον κωδικό ' + msg.code + ' στον φίλο σου.');
          showGame('Online Host');
        } else if (msg.type === 'room_joined') {
          roomCode = msg.code;
          setStatus('Μπήκες στο δωμάτιο ' + msg.code + '.');
          showGame('Online Guest');
        } else if (msg.type === 'guest_joined') {
          setStatus('Ο δεύτερος παίκτης μπήκε στο δωμάτιο ' + msg.code + '.');
        } else if (msg.type === 'error') {
          setStatus('Σφάλμα: ' + msg.message);
        } else if (msg.type === 'peer_left') {
          setStatus('Ο άλλος παίκτης αποσυνδέθηκε.');
        }
      };

      socket.onclose = () => {
        if (roomCode) setStatus('Η σύνδεση με τον server έκλεισε.');
      };
    }

    document.getElementById('playAiBtn').addEventListener('click', () => {
      roomCode = null;
      showGame('Με AI');
      setStatus('Άνοιξε το παιχνίδι σε λειτουργία AI.');
    });

    document.getElementById('playLocalBtn').addEventListener('click', () => {
      roomCode = null;
      showGame('2 Παίκτες Τοπικά');
      setStatus('Άνοιξε το παιχνίδι σε τοπική λειτουργία.');
    });

    document.getElementById('createRoomBtn').addEventListener('click', () => {
      if (!socket || socket.readyState > 1) connectSocket();
      const waitSend = () => {
        if (socket.readyState === 1) socket.send(JSON.stringify({ type:'create_room' }));
        else setTimeout(waitSend, 150);
      };
      waitSend();
      setStatus('Δημιουργία δωματίου...');
    });

    document.getElementById('joinRoomBtn').addEventListener('click', () => {
      const code = normalizeCode(roomCodeInput.value);
      roomCodeInput.value = code;
      if (code.length !== 4) {
        setStatus('Βάλε έγκυρο 4ψήφιο κωδικό.');
        return;
      }
      if (!socket || socket.readyState > 1) connectSocket();
      const waitSend = () => {
        if (socket.readyState === 1) socket.send(JSON.stringify({ type:'join_room', code }));
        else setTimeout(waitSend, 150);
      };
      waitSend();
      setStatus('Προσπάθεια εισόδου στο δωμάτιο ' + code + '...');
    });

    document.getElementById('backBtn').addEventListener('click', () => {
      location.reload();
    });
  </script>
</body>
</html>
